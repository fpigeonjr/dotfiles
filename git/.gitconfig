[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[user]
	name = Frank Pigeon Jr.
	email = 4629398+fpigeonjr@users.noreply.github.com
	signingkey = ~/.ssh/id_ed25519.pub
	username = fpigeonjr

# Machine-local overrides (email, signingkey, etc.)
# Create ~/.gitconfig.local on any machine that needs different values.
# Safe no-op if the file does not exist.
[includeIf "gitdir:~/"]
	path = ~/.gitconfig.local

[init]
	defaultBranch = main

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global

[gpg]
	format = ssh

[commit]
	gpgsign = true

[pull]
	rebase = true

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
