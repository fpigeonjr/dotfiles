# AWS CLI config — template only, real values are never committed.
#
# After cloning on a new machine:
#   1. stow aws             (creates ~/.aws/config symlink to this template)
#   2. stow -D aws          (breaks symlink, this file is now safe to leave as-is)
#   3. cp ~/dotfiles/aws/.aws/config ~/.aws/config  (create standalone file)
#   4. Edit ~/.aws/config with real values from your org's onboarding docs.
#
# OR skip stowing aws entirely and create ~/.aws/config manually from scratch.

[profile employer-bedrock]
sso_start_url  = https://REPLACE-WITH-YOUR-ORG.awsapps.com/start
sso_region     = us-east-2
sso_account_id = 000000000000
sso_role_name  = REPLACE-WITH-ROLE-NAME
region         = us-east-2
