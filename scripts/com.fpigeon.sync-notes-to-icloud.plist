<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.fpigeon.sync-notes-to-icloud</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__HOME__/dotfiles/scripts/sync-notes-to-icloud-export.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>900</integer>

  <key>WorkingDirectory</key>
  <string>__HOME__/dotfiles</string>

  <key>StandardOutPath</key>
  <string>__HOME__/.local/share/logs/launchd-sync-notes-to-icloud.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/.local/share/logs/launchd-sync-notes-to-icloud.log</string>
</dict>
</plist>
